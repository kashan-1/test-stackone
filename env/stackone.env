# Nginx root path
NGINX_PATH=/var/www/tools

# Hosts entries
HOSTS_ENTRIES="tools.local jenkins.local code.local grafana.local prometheus.local node-exporter.local traefik.local"

# Docker compose file
DOCKER_COMPOSE_FILE=/docker/docker-compose.yml

# Custom index file
INDEX_FILE=index.html

# SSL settings
SSL_DIR=/etc/nginx/ssl
CERT_NAME=devops-local